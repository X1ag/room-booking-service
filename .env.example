POSTGRES_DB=room_booking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_ENV=docker
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

DB_HOST=postgres
DB_PORT=5432
DB_NAME=room_booking
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

MIGRATIONS_PATH=file://migrations

JWT_SECRET=local-dev-secret-change-me
JWT_TOKEN_TTL=24h
DUMMY_ADMIN_ID=11111111-1111-1111-1111-111111111111
DUMMY_USER_ID=22222222-2222-2222-2222-222222222222

LOGGER_LEVEL=debug
LOGGER_NO_COLOR=false
LOGGER_TIME_FORMAT=2006-01-02T15:04:05Z
LOGGER_TIME_LOCATION=UTC
LOGGER_PARTS_ORDER=time,level,logger,message
LOGGER_PARTS_EXCLUDE=
LOGGER_FIELDS_ORDER=
LOGGER_FIELDS_EXCLUDE=
LOGGER_LOGS_DIR=./logs
